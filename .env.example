# Database Configuration
DB_URL=jdbc:postgresql://your-vps-host:5432/wordwaverise
DB_USER=your_db_username
DB_PASSWORD=your_db_password
DB_DRIVER=org.postgresql.Driver

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_ISSUER=wordwaverise-backend
JWT_AUDIENCE=wordwaverise-app
JWT_REALM=Access to WordWaverise API
JWT_EXPIRATION_HOURS=720

# Application Configuration
APP_ENV=development

# Dictionary API Configuration (Optional)
# Get free API key at https://www.wordsapi.com/
# If not set, the system will work with Free Dictionary and DataMuse APIs only
WORDS_API_KEY=your_words_api_key_here
